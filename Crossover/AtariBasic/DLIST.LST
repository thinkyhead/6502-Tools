;
; DLIST
; Print the current display list
;

100 MODE=0:O.#1,8,0,"S:"
;101G.2000
102 DIM A$(10):DONE=0:PV=-1:PC=0
105 DIM G$(8),M$(15):G$="TEXTGRFX":M$=" 0***123456*7*8"
110 GR.MODE:POK.752,1:DL=PEEK(560)+256*PEEK(561):?#1;"Display List at $";:A=560:GOS.1310:?#1;" (";DL;")"
120 F.I=0TO255:D=DL+I:V=PEEK(D):GOS.1000:IFNOTDONE THENN.I
129 CL.#1
130 POK.752,0:END

1000 IFPV=V THENPC=PC+1:RET.
1001 PV=V:IFPC THEN?#1;"         (...x";PC+1;")":PC=0
1005 A=D:GOS.1320:?#1;" ";
1010 NH=INT(V/16):NL=V-NH*16:TH=NH
1011 DLI=TH>=8:IFDLI THENTH=TH-8
1012 LMS=TH>=4:IFLMS THENTH=TH-4
1013 VSC=TH>=2:IFVSC THENTH=TH-2
1014 HSC=TH
1020 IFV<100 THEN?#1;" ";:IFV<10 THEN?#1;" ";
1021 ?#1;V;" ";
1100 IFNL=0 THEN?#1;"SKIP";NH+1-(NH>7)*8:RET.
1110 IFNL=1 AND LMS THEN?#1;"JWVB";:DONE=1:G.1201
1111 IFNL=1 THEN?#1;"JUMP";:G.1201
1200 N=1+4*(NL>8):?#1;G$(N,N+3);M$(NL,NL);
1201 IFDLI THEN?#1;"+DLI";
1202 IFLMS THEN?#1;"+LMS(";:GOS.1300:?#1;")";
1203 IFVSC THEN?#1;"+VSCROL";
1204 IFHSC THEN?#1;"+HSCROL";
1205 ?#1:RET.
1300 A=D+1:I=I+2
1310 X=PEEK(A+1):GOS.1330:X=PEEK(A):G.1330
1320 X=INT(A/256):GOS.1330:X=A-X*256
1330 N=INT(X/16):GOS.1340:N=X-N*16
1340 C=N+48:IFC>57 THENC=C+7
1341 ?#1;CHR$(C);:RET.

; Look at some registers
2000 GOS.3000:SZ=(P106-4)*256:IFSZ<=PEEK(144)+256*PEEK(145)THEN?"LOW MEMORY!":STOP
2001 GOS.5000:POKE106,P106-4:GR.MODE:POK.752,1:.MOVE DL DATA
2002 GOS.3000:G.130

3000 A=PEEK(512)+256*PEEK(513):?#1;"VDSLST=";STR$(A):.NMI for DLI
3001 P106=PEEK(106):?#1;"MEMTOP=";P106;" (";P106*256;")"
3002 C=PEEK(14)+256*PEEK(15):?#1;"APPMHI=";C
3003 ?#1;"FREE=";B*256-C
3004 DL=PEEK(560)+256*PEEK(561):?#1;"SDLSTL=";DL
3999 RET.

5000 ?"?";:O.#3,4,0,"K:":GET#3,K:CL.#3:?:RET.

9998 G.130
9999 S."D:DLIST.BAS":? "Saved!"
